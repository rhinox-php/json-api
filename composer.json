{
    "name": "rhinox/json-api",
    "description": "A PHP library for serializing data according to the JSON:API specification",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "rhinox/input-data": "^0.9.12",
        "symfony/validator": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Rhinox\\JsonApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rhinox\\JsonApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "@php -d xdebug.mode=coverage vendor/bin/phpunit --coverage-text --coverage-html coverage",
        "phpstan": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
